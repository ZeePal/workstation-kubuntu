#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
    echo "ERROR: missing command to agentwrap-bwrap" >&2
    exit 1
fi

# shellcheck source=../../../opt/agentwrap/agentwrap.conf
source /opt/agentwrap/agentwrap.conf

allowed_env_names=("${PASSTHROUGH_ENV_VARS[@]}")

current_uid="$(id -u)"
current_gid="$(id -g)"
current_user="${USER:-$(id -un)}"
current_group="$(id -gn)"
current_shell="${SHELL:-/bin/sh}"

root_passwd_entry="$(getent passwd 0 || true)"
if [[ -z "$root_passwd_entry" ]]; then
    root_passwd_entry='root:x:0:0:root:/root:/usr/sbin/nologin'
fi

user_passwd_entry="$(getent passwd "$current_uid" || true)"
if [[ -z "$user_passwd_entry" ]]; then
    user_passwd_entry="${current_user}:x:${current_uid}:${current_gid}:${current_user}:${HOME}:${current_shell}"
fi

root_group_entry="$(getent group 0 || true)"
if [[ -z "$root_group_entry" ]]; then
    root_group_entry='root:x:0:'
fi

user_group_entry="$(getent group "$current_gid" || true)"
if [[ -z "$user_group_entry" ]]; then
    user_group_entry="${current_group}:x:${current_gid}:"
fi

# Keep identity files minimal to avoid leaking host account/group metadata.
passwd_lines=("$root_passwd_entry")
if [[ "$user_passwd_entry" != "$root_passwd_entry" ]]; then
    passwd_lines+=("$user_passwd_entry")
fi
if nobody_entry="$(getent passwd 65534 2>/dev/null)"; then
    if [[ "$nobody_entry" != "$root_passwd_entry" && "$nobody_entry" != "$user_passwd_entry" ]]; then
        passwd_lines+=("$nobody_entry")
    fi
fi
printf -v passwd_content '%s\n' "${passwd_lines[@]}"
passwd_content="${passwd_content%$'\n'}"

group_lines=("$root_group_entry")
if [[ "$user_group_entry" != "$root_group_entry" ]]; then
    group_lines+=("$user_group_entry")
fi
if nogroup_entry="$(getent group 65534 2>/dev/null)"; then
    if [[ "$nogroup_entry" != "$root_group_entry" && "$nogroup_entry" != "$user_group_entry" ]]; then
        group_lines+=("$nogroup_entry")
    fi
fi
printf -v group_content '%s\n' "${group_lines[@]}"
group_content="${group_content%$'\n'}"

exec {passwd_fd}<<<"$passwd_content"
exec {group_fd}<<<"$group_content"

if [[ ! -x /opt/agentwrap/bin/agentwrap-seccomp ]]; then
    echo "ERROR: missing required seccomp helper: /opt/agentwrap/bin/agentwrap-seccomp" >&2
    exit 1
fi

exec {seccomp_fd}< <(/opt/agentwrap/bin/agentwrap-seccomp)

# if AWS creds have been requested, grab and passthrough
if [[ -n ${AGENTWRAP_AWS_PROFILE:-} ]]; then
    # "true" is to defer the profile lookup to the normal profile env var
    aws_profile_to_export=""
    if [[ "$AGENTWRAP_AWS_PROFILE" == "true" ]]; then
        aws_profile_to_export="${AWS_PROFILE:-}"
    else
        aws_profile_to_export="$AGENTWRAP_AWS_PROFILE"
    fi

    if [[ -n "$aws_profile_to_export" ]]; then
        while IFS= read -r line; do
            if [[ "$line" != *=* ]]; then
                continue
            fi

            key="${line%%=*}"
            value="${line#*=}"
            case "$key" in
            AWS_ACCESS_KEY_ID | AWS_SECRET_ACCESS_KEY | AWS_SESSION_TOKEN | AWS_CREDENTIAL_EXPIRATION)
                if [[ "$value" == \"*\" && "$value" == *\" ]]; then
                    value="${value:1:-1}"
                elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
                    value="${value:1:-1}"
                fi
                export "$key=$value"
                allowed_env_names+=("$key")
                ;;
            esac
        done < <(aws configure export-credentials --profile "$aws_profile_to_export" --format env-no-export)
    fi
fi

# if GCP creds have been requested, impersonate and passthrough
if [[ -n ${AGENTWRAP_GCP_SA:-} ]]; then
    gcp_token="$(gcloud auth print-access-token --impersonate-service-account="$AGENTWRAP_GCP_SA")"
    export GOOGLE_OAUTH_ACCESS_TOKEN="$gcp_token"
    export CLOUDSDK_AUTH_ACCESS_TOKEN="$gcp_token"
    allowed_env_names+=(GOOGLE_OAUTH_ACCESS_TOKEN CLOUDSDK_AUTH_ACCESS_TOKEN)
fi

# Find where the writable directory should start (PWD or the root of the Git repo)
workspace="$(git -C "${PWD:-.}" rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$workspace" ]]; then
    workspace="$PWD"
fi

binds_extra_ro=()
for bind in "${EXTRA_RO[@]}"; do
    if [[ -e "$bind" ]]; then
        binds_extra_ro+=(--ro-bind-try "$bind" "$bind")
    fi
done

binds_extra_rw=()
for bind in "${EXTRA_RW[@]}"; do
    if [[ -e "$bind" ]]; then
        binds_extra_rw+=(--bind-try "$bind" "$bind")
    fi
done

bwrap_args=(
    --unshare-all
    --share-net
    --unshare-user
    --die-with-parent
    --new-session
    --ro-bind /usr /usr
    --ro-bind /lib /lib
    --ro-bind /lib64 /lib64
    --ro-bind /bin /bin
    --ro-bind /sbin /sbin
    --proc /proc
    --dev /dev
    --tmpfs /dev/shm
    --tmpfs /tmp
    --tmpfs /run
    --ro-bind /etc/resolv.conf /etc/resolv.conf
    --ro-bind /etc/hosts /etc/hosts
    --perms 0644
    --ro-bind-data "$passwd_fd" /etc/passwd
    --perms 0644
    --ro-bind-data "$group_fd" /etc/group
    --ro-bind /etc/localtime /etc/localtime
    --ro-bind /etc/alternatives /etc/alternatives
    --ro-bind-try /etc/ssl/certs /etc/ssl/certs
    --ro-bind-try /etc/ca-certificates /etc/ca-certificates
    --dir "$HOME"
    --chdir "$PWD"
    --setenv PATH "$AGENTWRAP_PATH"
    --seccomp "$seccomp_fd"
)

bwrap_args+=("${binds_extra_ro[@]}")
bwrap_args+=("${binds_extra_rw[@]}")
# Keep the active workspace writable while the rest of the filesystem stays
# read-only or synthetic unless explicitly bound above.
bwrap_args+=(--bind "$workspace" "$workspace")

# Keep selected workspace-root control paths read-only even though the
# workspace root itself is writable.
for carveout_name in "${WORKSPACE_ROOT_RO_CARVEOUTS[@]}"; do
    carveout_path="$workspace/$carveout_name"
    if [[ -e "$carveout_path" ]]; then
        bwrap_args+=(--ro-bind "$carveout_path" "$carveout_path")
    fi
done

# Strip/unset all envvars not to be passed through to the sandbox
for current_var in $(compgen -e); do
    keep_var="0"
    for allowed_var in "${allowed_env_names[@]}"; do
        if [[ "$current_var" == "$allowed_var" ]]; then
            keep_var="1"
            break
        fi
    done
    if [[ "$keep_var" == "0" ]]; then
        unset "$current_var"
    fi
done

exec /usr/bin/bwrap "${bwrap_args[@]}" -- "$@"
