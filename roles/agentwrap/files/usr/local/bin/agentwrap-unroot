#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
    echo "ERROR: missing command to agentwrap-unroot" >&2
    exit 1
fi

# shellcheck source=../../../opt/agentwrap/agentwrap.conf
source /opt/agentwrap/agentwrap.conf

for var in "${SUDO_WRAP_ENV_VARS[@]}"; do
    prefixed_var="AGENTWRAP_PASS_${var}"
    if [[ -n "${!prefixed_var+set}" ]]; then
        export "$var=${!prefixed_var}"
    fi
done

for var in "${PASSTHROUGH_ENV_VARS[@]}"; do
    prefixed_var="AGENTWRAP_PASS_${var}"
    if [[ -n "${!prefixed_var+set}" ]]; then
        export "$var=${!prefixed_var}"
    fi
done

exec /usr/local/bin/agentwrap-bwrap "$@"
