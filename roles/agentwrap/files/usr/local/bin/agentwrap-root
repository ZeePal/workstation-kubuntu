#!/usr/bin/env bash
set -euo pipefail

if [[ ${EUID} -ne 0 ]]; then
    echo "ERROR: agentwrap-root must run as root" >&2
    exit 1
fi

if [[ -z ${SUDO_UID:-} || -z ${SUDO_GID:-} ]]; then
    echo "ERROR: agentwrap-root must be run via sudo" >&2
    exit 1
fi

if [[ $# -eq 0 ]]; then
    echo "ERROR: missing command to agentwrap-root" >&2
    exit 1
fi

exec /usr/bin/nsenter --net=/run/netns/agentwrap-egress -- \
    /usr/bin/setpriv --reuid "$SUDO_UID" --regid "$SUDO_GID" --init-groups --no-new-privs \
    /usr/local/bin/agentwrap-unroot "$@"
