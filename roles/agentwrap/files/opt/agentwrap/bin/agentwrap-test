#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../agentwrap.conf.example
source /opt/agentwrap/agentwrap.conf

private_url="${1:-}"
curl_timeout_seconds="${AGENTWRAP_TEST_CURL_TIMEOUT:-2}"
google_ipv4=""

if [[ -n "$private_url" && ! "$private_url" =~ ^https?:// ]]; then
    echo "ERROR: private target must be http://... or https://..." >&2
    exit 1
fi

while read -r ip _; do
    google_ipv4="$ip"
    break
done < <(getent ahostsv4 google.com)

test_root="${TMPDIR:-/tmp}/agentwrap-test-$$"
hidden_host_path="$test_root/hidden.txt"
rw_dir="${EXTRA_RW_DIRS[0]}"
ro_dir="${EXTRA_RO_DIRS[0]}"
workspace_rw_file="$PWD/.agentwrap-test-rw-$$"
extra_rw_file="$rw_dir/.agentwrap-test-rw-$$"
extra_ro_file="$ro_dir/.agentwrap-test-ro-$$"

cleanup() {
    rm -f "$workspace_rw_file" "$extra_rw_file" "$extra_ro_file"
    rm -rf "$test_root"
}
trap cleanup EXIT

mkdir -p "$test_root" "$rw_dir" "$ro_dir"
printf 'hidden\n' >"$hidden_host_path"
rm -f "$workspace_rw_file" "$extra_rw_file" "$extra_ro_file"

if [[ -t 1 ]]; then
    color_pass=$'\033[32m'
    color_fail=$'\033[31m'
    color_skip=$'\033[33m'
    color_reset=$'\033[0m'
else
    color_pass=''
    color_fail=''
    color_skip=''
    color_reset=''
fi

run_suite() {
    local runner="$1"
    local label
    local failures=0
    label="$(basename "$runner")"

    run_check() {
        local name="$1"
        shift
        if "$@"; then
            printf '[%s] %sPASS%s %s\n' "$label" "$color_pass" "$color_reset" "$name"
        else
            printf '[%s] %sFAIL%s %s\n' "$label" "$color_fail" "$color_reset" "$name" >&2
            failures=1
        fi
    }

    run_skip() {
        local name="$1"
        printf '[%s] %sSKIP%s %s\n' "$label" "$color_skip" "$color_reset" "$name"
    }

    run_curl_expect_connect() {
        local url="$1"
        local code
        local -a curl_cmd=(
            "$runner"
            curl
            -k
            --silent
            --show-error
            --output /dev/null
            --write-out '%{http_code}'
            --connect-timeout "$curl_timeout_seconds"
            --max-time "$curl_timeout_seconds"
            "$url"
        )
        code="$("${curl_cmd[@]}")"
        [[ -n "$code" && "$code" != "000" ]]
    }

    run_curl_expect_block() {
        local url="$1"
        local -a curl_cmd=(
            "$runner"
            curl
            -k
            --silent
            --show-error
            --output /dev/null
            --write-out '%{http_code}'
            --connect-timeout "$curl_timeout_seconds"
            --max-time "$curl_timeout_seconds"
            "$url"
        )
        if "${curl_cmd[@]}" >/dev/null 2>&1; then
            return 1
        fi
        return 0
    }

    if [[ -n "$google_ipv4" ]]; then
        run_check 'internet IPv4 HTTPS reachability via resolved google.com address' run_curl_expect_connect "https://$google_ipv4"
    else
        run_skip 'internet IPv4 HTTPS reachability via resolved google.com address'
    fi

    run_check 'internet DNS HTTPS reachability for google.com' run_curl_expect_connect https://google.com
    run_check 'hidden host path is not visible' "$runner" bash -lc '[ ! -e "$1" ]' _ "$hidden_host_path"

    run_check 'workspace bind accepts writes' "$runner" bash -lc 'printf ok > "$1"' _ "$workspace_rw_file"
    run_check 'workspace bind write is visible on host' test -f "$workspace_rw_file"
    rm -f "$workspace_rw_file"

    run_check 'configured extra RW path accepts writes' "$runner" bash -lc 'printf ok > "$1"' _ "$extra_rw_file"
    run_check 'configured extra RW write is visible on host' test -f "$extra_rw_file"
    rm -f "$extra_rw_file"

    if "$runner" bash -lc 'printf no > "$1"' _ "$extra_ro_file" >/dev/null 2>&1; then
        printf '[%s] %sFAIL%s configured extra RO path unexpectedly writable\n' "$label" "$color_fail" "$color_reset" >&2
        failures=1
    else
        run_check 'configured extra RO path blocks writes' test ! -e "$extra_ro_file"
    fi

    if [[ -z "$private_url" ]]; then
        run_skip 'private URL checks (provide http://... or https://... to enable)'
    elif [[ "$label" == "agentwrap" ]]; then
        run_check 'private URL is blocked by network isolation' run_curl_expect_block "$private_url"
    else
        run_check 'private URL is reachable without network isolation' run_curl_expect_connect "$private_url"
    fi

    return "$failures"
}

run_suite agentwrap &
pid_agentwrap=$!

run_suite agentwrap-bwrap &
pid_bwrap=$!

status=0
wait "$pid_agentwrap" || status=1
wait "$pid_bwrap" || status=1

exit "$status"
