#!/usr/bin/env bash
set -euo pipefail

# shellcheck disable=SC1091 # Config file exists only on installed target path.
# shellcheck source=../agentwrap/agentwrap.conf
source /opt/agentwrap/agentwrap.conf

private_url="${1:-}"
curl_timeout_seconds="${AGENTWRAP_TEST_CURL_TIMEOUT:-2}"
google_ipv4=""
have_python3='0'
have_node='0'
have_git='0'
have_script='0'

if [[ -n "$private_url" && ! "$private_url" =~ ^https?:// ]]; then
    echo "ERROR: private target must be http://... or https://..." >&2
    exit 1
fi

while read -r ip _; do
    google_ipv4="$ip"
    break
done < <(getent ahostsv4 google.com)

if command -v python3 >/dev/null 2>&1; then
    have_python3='1'
fi

if command -v node >/dev/null 2>&1; then
    have_node='1'
fi

if command -v git >/dev/null 2>&1; then
    have_git='1'
fi

if command -v script >/dev/null 2>&1; then
    have_script='1'
fi

test_root="${TMPDIR:-/tmp}/agentwrap-test-$$"
hidden_host_path="$test_root/hidden.txt"
rw_dir="${EXTRA_RW_DIRS[0]}"
ro_dir="${EXTRA_RO_DIRS[0]}"
workspace_rw_file="$PWD/.agentwrap-test-rw-$$"
extra_rw_file="$rw_dir/.agentwrap-test-rw-$$"
extra_ro_file="$ro_dir/.agentwrap-test-ro-$$"

# shellcheck disable=SC2317,SC2329 # Invoked by trap on script exit.
cleanup() {
    rm -f "$workspace_rw_file" "$extra_rw_file" "$extra_ro_file"
    rm -rf "$test_root"
}
trap cleanup EXIT

mkdir -p "$test_root" "$rw_dir" "$ro_dir"
printf 'hidden\n' >"$hidden_host_path"
rm -f "$workspace_rw_file" "$extra_rw_file" "$extra_ro_file"

if [[ -t 1 ]]; then
    color_pass=$'\033[32m'
    color_fail=$'\033[31m'
    color_skip=$'\033[33m'
    color_reset=$'\033[0m'
else
    color_pass=''
    color_fail=''
    color_skip=''
    color_reset=''
fi

# shellcheck disable=SC2317 # Indirectly invoked via run_check in parallel suites.
print_pass() {
    local label="$1"
    local name="$2"
    printf '[%s] %sPASS%s %s\n' "$label" "$color_pass" "$color_reset" "$name"
}

# shellcheck disable=SC2317 # Indirectly invoked via run_check in parallel suites.
print_fail() {
    local label="$1"
    local name="$2"
    printf '[%s] %sFAIL%s %s\n' "$label" "$color_fail" "$color_reset" "$name" >&2
}

# shellcheck disable=SC2317 # Used conditionally for optional test cases.
print_skip() {
    local label="$1"
    local name="$2"
    printf '[%s] %sSKIP%s %s\n' "$label" "$color_skip" "$color_reset" "$name"
}

# shellcheck disable=SC2317,SC2329 # Indirectly invoked through expect_* helpers.
run_curl() {
    local runner="$1"
    shift
    "$runner" curl \
        --insecure \
        --silent \
        --show-error \
        --output /dev/null \
        --write-out '%{http_code}' \
        --connect-timeout "$curl_timeout_seconds" \
        --max-time "$curl_timeout_seconds" \
        "$@"
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_connect() {
    local runner="$1"
    local url="$2"
    local code
    code="$(run_curl "$runner" "$url")"
    [[ -n "$code" && "$code" != "000" ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_connect_resolved() {
    local runner="$1"
    local host="$2"
    local ip="$3"
    local code
    code="$(run_curl "$runner" --resolve "$host:443:$ip" "https://$host")"
    [[ -n "$code" && "$code" != "000" ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_block() {
    local runner="$1"
    local url="$2"
    if run_curl "$runner" "$url" >/dev/null 2>&1; then
        return 1
    fi
    return 0
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_seccomp_mode() {
    local runner="$1"
    "$runner" bash -lc "grep -Eq '^Seccomp:[[:space:]]+2$' /proc/self/status"
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_ptrace_blocked() {
    local runner="$1"
    local result
    result="$(
        "$runner" python3 -c 'import ctypes
libc = ctypes.CDLL(None, use_errno=True)
rc = libc.ptrace(0, 0, None, None)
print("%s %s" % (rc, ctypes.get_errno()))'
    )"
    [[ "$result" == '-1 1' ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_thread_creation() {
    local runner="$1"
    local result
    result="$(
        "$runner" python3 -c 'import threading

result = []

def worker():
    result.append("ok")

thread = threading.Thread(target=worker)
thread.start()
thread.join()
print(result[0] if result else "fail")'
    )"
    [[ "$result" == 'ok' ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_python_getaddrinfo() {
    local runner="$1"
    local result
    result="$(
        "$runner" python3 -c 'import socket
result = socket.getaddrinfo("google.com", 443)
print("ok" if result else "fail")'
    )"
    [[ "$result" == 'ok' ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_python_ssl() {
    local runner="$1"
    local result
    result="$(
        "$runner" python3 -c 'import ssl
ctx = ssl.create_default_context()
print("ok" if ctx else "fail")'
    )"
    [[ "$result" == 'ok' ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_python_subprocess() {
    local runner="$1"
    local result
    result="$(
        "$runner" python3 -c 'import subprocess
completed = subprocess.run(["true"], check=False)
print("ok" if completed.returncode == 0 else "fail")'
    )"
    [[ "$result" == 'ok' ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_node_runtime() {
    local runner="$1"
    local result
    result="$("$runner" node -e 'process.stdout.write("ok")')"
    [[ "$result" == 'ok' ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_node_spawn_sync() {
    local runner="$1"
    local result
    result="$(
        "$runner" node -e 'const cp = require("node:child_process");
const out = cp.spawnSync("true", [], { stdio: "ignore" });
process.stdout.write(out.status === 0 ? "ok" : "fail");'
    )"
    [[ "$result" == 'ok' ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_git_status() {
    local runner="$1"
    "$runner" git -C "$PWD" status --short >/dev/null
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_git_toplevel() {
    local runner="$1"
    local result
    result="$("$runner" git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)"
    [[ -n "$result" ]]
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_pty_basic() {
    local runner="$1"
    "$runner" script -q -c true /dev/null >/dev/null
}

# shellcheck disable=SC2317,SC2329 # Passed by name into run_check.
expect_userns_blocked() {
    local runner="$1"
    "$runner" bash -lc 'unshare -U true >/dev/null 2>&1; test $? -ne 0'
}

# shellcheck disable=SC2317 # Called before definition and within backgrounded suites.
run_check() {
    local label="$1"
    local name="$2"
    shift 2
    if "$@"; then
        print_pass "$label" "$name"
        return 0
    fi
    print_fail "$label" "$name"
    return 1
}

# shellcheck disable=SC2317 # Invoked in background jobs below.
run_suite() {
    local runner="$1"
    local label
    local failures=0
    label="$(basename "$runner")"

    if [[ -n "$google_ipv4" ]]; then
        run_check "$label" 'internet HTTPS reachability without sandbox DNS using --resolve' \
            expect_connect_resolved "$runner" google.com "$google_ipv4" || failures=1
    else
        print_skip "$label" 'internet HTTPS reachability without sandbox DNS using --resolve'
    fi

    run_check "$label" 'internet DNS HTTPS reachability for google.com' \
        expect_connect "$runner" https://google.com || failures=1

    run_check "$label" 'seccomp filter is active' \
        expect_seccomp_mode "$runner" || failures=1

    run_check "$label" 'user namespace creation is blocked' \
        expect_userns_blocked "$runner" || failures=1

    if [[ "$have_python3" == '1' ]]; then
        run_check "$label" 'python getaddrinfo works' \
            expect_python_getaddrinfo "$runner" || failures=1

        run_check "$label" 'python ssl default context works' \
            expect_python_ssl "$runner" || failures=1

        run_check "$label" 'python subprocess works' \
            expect_python_subprocess "$runner" || failures=1

        run_check "$label" 'normal thread creation still works' \
            expect_thread_creation "$runner" || failures=1

        run_check "$label" 'ptrace is blocked by seccomp' \
            expect_ptrace_blocked "$runner" || failures=1
    else
        print_skip "$label" 'python getaddrinfo works (python3 unavailable)'
        print_skip "$label" 'python ssl default context works (python3 unavailable)'
        print_skip "$label" 'python subprocess works (python3 unavailable)'
        print_skip "$label" 'normal thread creation still works (python3 unavailable)'
        print_skip "$label" 'ptrace is blocked by seccomp (python3 unavailable)'
    fi

    if [[ "$have_node" == '1' ]]; then
        run_check "$label" 'node runtime works' \
            expect_node_runtime "$runner" || failures=1

        run_check "$label" 'node spawnSync works' \
            expect_node_spawn_sync "$runner" || failures=1
    else
        print_skip "$label" 'node runtime works (node unavailable)'
        print_skip "$label" 'node spawnSync works (node unavailable)'
    fi

    if [[ "$have_git" == '1' ]]; then
        run_check "$label" 'git status works' \
            expect_git_status "$runner" || failures=1

        run_check "$label" 'git toplevel discovery works' \
            expect_git_toplevel "$runner" || failures=1
    else
        print_skip "$label" 'git status works (git unavailable)'
        print_skip "$label" 'git toplevel discovery works (git unavailable)'
    fi

    if [[ "$have_script" == '1' ]]; then
        run_check "$label" 'pty allocation works' \
            expect_pty_basic "$runner" || failures=1
    else
        print_skip "$label" 'pty allocation works (script unavailable)'
    fi

    run_check "$label" 'hidden host path is not visible' \
        "$runner" bash -lc "[ ! -e \"\$1\" ]" _ "$hidden_host_path" || failures=1

    run_check "$label" 'workspace bind accepts writes' \
        "$runner" bash -lc "printf ok > \"\$1\"" _ "$workspace_rw_file" || failures=1
    run_check "$label" 'workspace bind write is visible on host' \
        test -f "$workspace_rw_file" || failures=1
    rm -f "$workspace_rw_file"

    run_check "$label" 'configured extra RW path accepts writes' \
        "$runner" bash -lc "printf ok > \"\$1\"" _ "$extra_rw_file" || failures=1
    run_check "$label" 'configured extra RW write is visible on host' \
        test -f "$extra_rw_file" || failures=1
    rm -f "$extra_rw_file"

    if "$runner" bash -lc "printf no > \"\$1\"" _ "$extra_ro_file" >/dev/null 2>&1; then
        print_fail "$label" 'configured extra RO path unexpectedly writable'
        failures=1
    else
        run_check "$label" 'configured extra RO path blocks writes' \
            test ! -e "$extra_ro_file" || failures=1
    fi

    if [[ -z "$private_url" ]]; then
        print_skip "$label" 'private URL checks (provide http://... or https://... to enable)'
    elif [[ "$label" == "agentwrap" ]]; then
        run_check "$label" 'private URL is blocked by network isolation' \
            expect_block "$runner" "$private_url" || failures=1
    else
        run_check "$label" 'private URL is reachable without network isolation' \
            expect_connect "$runner" "$private_url" || failures=1
    fi

    return "$failures"
}

run_suite agentwrap &
pid_agentwrap=$!

run_suite agentwrap-bwrap &
pid_bwrap=$!

status=0
wait "$pid_agentwrap" || status=1
wait "$pid_bwrap" || status=1

exit "$status"
